{
  "cleanUrls": true,
  "routes": [
    { "src": "/api/ai-bill-parser", "dest": "/api/ai-bill-parser.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/driver", "dest": "/index.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/driver(.*)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
